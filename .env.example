SECRET_KEY=change-me-to-random-string
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# SMTP — выберите один из вариантов ниже
# ============================================================

# --- Яндекс.Почта (РЕКОМЕНДУЕТСЯ для старта, ~500 писем/день, БЕСПЛАТНО) ---
# Как включить:
#   1. mail.yandex.ru → Все настройки → Почтовые программы → включить IMAP
#   2. Там же → Безопасность → Пароли приложений → Создать пароль → выбрать "Почта"
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=ваш@yandex.ru
SMTP_PASS=пароль_приложения

# --- SendPulse (15 000 писем/МЕСЯЦ бесплатно, российский сервис) ---
# Как получить:
#   1. Зарегистрируйтесь на sendpulse.com
#   2. Настройки → SMTP → Активировать → скопируйте логин и пароль
# SMTP_HOST=smtp.sendpulse.com
# SMTP_PORT=465
# SMTP_USER=ваш_логин_sendpulse
# SMTP_PASS=ваш_пароль_sendpulse

# --- Mail.ru (~500 писем/день, БЕСПЛАТНО) ---
# Как включить: Настройки → Безопасность → Пароли для внешних приложений
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_USER=ваш@mail.ru
# SMTP_PASS=пароль_приложения

# --- Gmail (~500 писем/день с обычным, 2000 с Google Workspace) ---
# Как включить: Google Аккаунт → Безопасность → Двухэтапная аутентификация →
#               Пароли приложений → Создать
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=ваш@gmail.com
# SMTP_PASS=пароль_приложения

# ============================================================

FROM_EMAIL=ваш@yandex.ru
FROM_NAME=Название компании

# URL сайта (для ссылки отписки в письмах)
SITE_URL=http://localhost:5000
