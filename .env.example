SECRET_KEY=change-me-to-random-string
ANTHROPIC_API_KEY=sk-ant-...

# UniSender SMTP (бесплатно 1500 писем/мес): https://cp.unisender.com → Настройки → SMTP
# Логин: ваш логин UniSender
# Пароль: API-ключ из раздела "Интеграции → API ключи"
SMTP_HOST=smtp.unisender.com
SMTP_PORT=465
SMTP_USER=ваш_логин_unisender
SMTP_PASS=ваш_api_ключ_unisender

# --- Альтернатива: Яндекс.Почта (500 писем/день) ---
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=ваш@yandex.ru
# SMTP_PASS=пароль_приложения  (mail.yandex.ru → Настройки → Безопасность → Пароли приложений)

# --- Альтернатива: Mail.ru ---
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_USER=ваш@mail.ru
# SMTP_PASS=пароль_приложения

FROM_EMAIL=info@yourcompany.ru
FROM_NAME=Название компании

# URL сайта (для ссылки отписки)
SITE_URL=http://localhost:5000
